! waveqlab3d input file: test problem for mms on cartesian grid with friction

&problem_list
 name = 'Mont-Blanc_node-1_block-2_elastic_dom-n_traditional-6_res-100m_pml-0km', 
 response = 'elastic',
 problem = 'TPV5'
 nblocks = 2,
 t_final = 10d0, 
 CFL = 0.5d0,
 coupling = 'locked', 
 type_of_mesh = 'curvilinear', 
 material_source='hard-coded',	
 fd_type = 'traditional',
 order = 6,
 interpol = F,
 use_topography = T,
 w_stride = 1, 
 w_fault = F /

&block_list
btp(1)%nqrs = 101, 101, 321,
btp(1)%aqrs = -16d0, 0d0, -16d0,
btp(1)%bqrs =  0d0, 10d0,  16d0,
btp(1)%rho_s_p = 2.7d0, 3.464d0, 6d0,
btp(1)%lqrs = 1, 2, 1,
btp(1)%rqrs = 0, 1, 1,
btp(1)%pml_lqrs = F, F, F,
btp(1)%pml_rqrs = F, F, F,
btp(1)%npml = 20,
btp(1)%lc = 1d0,
btp(1)%rc = 0d0,
btp(1)%profile_type= 'no_path',
btp(1)%topography_type = 'read_topo_from_memory',
btp(1)%topography_path= './topo/Mont-Blanc_topo_100m_block1.dat',


btp(2)%nqrs = 161, 101, 321,
btp(2)%aqrs =  0d0, 0d0, -16d0,
btp(2)%bqrs =  16d0, 10d0,  16d0,
btp(2)%rho_s_p = 2.7d0, 3.464d0, 6d0,
btp(2)%lqrs = 0, 2, 1,
btp(2)%rqrs = 1, 1, 1,
btp(2)%pml_lqrs = F, F, F,
btp(2)%pml_rqrs = F, F, F,
btp(2)%npml = 20,
btp(2)%lc = 0d0,
btp(2)%rc = 1d0,
btp(2)%profile_type= 'no_path',
btp(2)%topography_type = 'read_topo_from_memory',
btp(2)%topography_path= './topo/Mont-Blanc_topo_100m_block2.dat',
/

&moment_list            
 use_moment_tensor = T,
 order = 4 /

!---begin:tensor_listU---
'cosine' 0.2d0 0d0 0d0 0d0 0d0 0d0 10d0 0d0 -5d0 1.8d0 -5d0 0
!---end:tensor_listU---

!---begin:tensor_listV---
'cosine' 0.2d0 0d0 0d0 0d0 0d0 0d0 10d0 0d0 -5d0 1.8d0 -5d0 0
!---end:tensor_listV---  


&mms_list
 use_mms = F /

&output_list
 output_exact_moment = F,
 output_seismograms = T,
 output_fault_topo = F,
 output_fields_block1 = F,
 output_fields_block2 = F,
 stride_fields = 1,
 station_xyz_index = T,
 station_list = 'infile',
 station_list_file = 'station_list_0y.txt',
 station_file_directory = 'dat_1tn_100m_n1b2',
 output_station_info = F
 /

!---begin:station_listU---
 -0d0 -0.89d0 0d0
 -1d0 0d0 2d0
  -1d0 -0.1365d0 2d0	
 -1d0 -0.49d0 -1d0
 -3d0 -0.2d0 0d0
 -3.5d0 0d0 -3.5d0	
 0d0 -0.2d0 -3d0
!---end:station_listU---

!---begin:station_listV---
 3d0 0d0 4d0
 4d0 0d0 6d0
 5d0 0d0 5d0
 1d0 -0.49d0 1d0
 3d0 -0.2d0 0d0
 0d0 -0.2d0 3d0
!---end:station_listV---


&plane_output_list
  enable_plane_output = T,
  nplanes = 1,
  plane_axis = 'qs',
  plane_coord = 1, 
  plane_name = 'y0_n1b2', 
  plane_stride = 1,
  plane_file_directory = 'plane'
/





